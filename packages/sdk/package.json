{
  "name": "@supergate/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Supergate LLM Gateway — unified API, key management, usage analytics, and BYOK.",
  "author": "Supergate",
  "license": "MIT",
  "homepage": "https://github.com/shivanshshekhar11/supergate#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/shivanshshekhar11/supergate.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/shivanshshekhar11/supergate/issues"
  },
  "keywords": [
    "llm", "gateway", "openai", "anthropic", "ai", "sdk",
    "multi-tenant", "rate-limiting", "semantic-cache", "byok"
  ],
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build":      "pnpm build:types && pnpm build:cjs && pnpm build:esm",
    "build:types": "tsc -p tsconfig.build.json --declaration --declarationMap --emitDeclarationOnly --outDir dist/types",
    "build:cjs":  "tsc -p tsconfig.build.json --module commonjs --outDir dist/cjs",
    "build:esm":  "tsc -p tsconfig.build.json --module es2022 --outDir dist/esm",
    "dev":        "tsc -p tsconfig.json --watch",
    "lint":       "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "openai": ">=4.0.0",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "openai": { "optional": true },
    "zod":    { "optional": true }
  },
  "devDependencies": {
    "@llm-gateway/schemas": "workspace:*",
    "openai": "^4.77.0",
    "typescript": "^5.7.2",
    "zod": "^3.24.1"
  },
  "engines": {
    "node": ">=18"
  }
}
